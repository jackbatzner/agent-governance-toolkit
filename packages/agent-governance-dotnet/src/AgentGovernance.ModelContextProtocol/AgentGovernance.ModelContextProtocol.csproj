<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <RootNamespace>AgentGovernance.Extensions</RootNamespace>
    <AssemblyName>AgentGovernance.ModelContextProtocol</AssemblyName>
    <Version>3.0.2</Version>
    <Description>Agent Governance Toolkit — MCP SDK adapter. Bridges the Agent Governance security pipeline into the official ModelContextProtocol C# SDK's filter system. One-line .WithGovernance() integration.</Description>
    <PackageId>Microsoft.AgentGovernance.ModelContextProtocol</PackageId>
    <Authors>Microsoft</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/microsoft/agent-governance-toolkit</PackageProjectUrl>
    <RepositoryUrl>https://github.com/microsoft/agent-governance-toolkit.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>agent;governance;mcp;model-context-protocol;security;owasp</PackageTags>
    <Copyright>© Microsoft Corporation. All rights reserved.</Copyright>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\AgentGovernance\AgentGovernance.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" Version="1.2.0" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

</Project>
